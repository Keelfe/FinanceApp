<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FinanceiroApp.Views.LancamentoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FinanceiroApp.ViewModels"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:DataType="vm:GastoViewModel"
    BackgroundColor="#F7F5F2"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="PrimaryColor">#A8C5DA</Color>
            <Color x:Key="PrimaryDark">#7BA8C2</Color>
            <Color x:Key="AccentColor">#F2A65A</Color>
            <Color x:Key="TextPrimary">#2D2D2D</Color>
            <Color x:Key="TextMuted">#9B9B9B</Color>
            <Color x:Key="ErrorColor">#E07070</Color>
            <Color x:Key="BackgroundColor">#F7F5F2</Color>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource SurfaceColor}" />
                <Setter Property="StrokeShape" Value="RoundRectangle 20" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="SectionLabelStyle" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource TextMuted}" />
                <Setter Property="CharacterSpacing" Value="1.5" />
                <Setter Property="TextTransform" Value="Uppercase" />
                <Setter Property="Margin" Value="4,0,0,8" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="24,52,24,24" Spacing="24">

                <!-- CABEÇALHO -->
                <Grid ColumnDefinitions="*, Auto" Margin="4,0">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="novo gasto" FontSize="13"
                               TextColor="{StaticResource TextMuted}"
                               CharacterSpacing="2" TextTransform="Uppercase" />
                        <Label Text="{Binding TotalMesAtual, StringFormat='Mês: {0}'}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 14"
                            Stroke="Transparent" BackgroundColor="{StaticResource PrimaryColor}"
                            Padding="14,10" VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CarregarGastosCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="📊" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- VALOR -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="VALOR" Style="{StaticResource SectionLabelStyle}" />
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="R$" FontSize="32"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDark}"
                                   VerticalOptions="End" Margin="0,0,0,4" />
                            <Entry Grid.Column="1" x:Name="ValorEntry"
                                   Text="{Binding ValorTexto}"
                                   Placeholder="0,00" Keyboard="Numeric"
                                   FontSize="32" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   PlaceholderColor="{StaticResource TextMuted}"
                                   BackgroundColor="Transparent" />
                        </Grid>
                        <BoxView HeightRequest="1.5" BackgroundColor="{StaticResource BackgroundColor}" />
                        <Label Text="{Binding MensagemErro}"
                               FontSize="12" TextColor="{StaticResource ErrorColor}"
                               IsVisible="{Binding MensagemErro, Converter={toolkit:IsNotNullOrEmptyConverter}}"
                               Margin="4,4,0,0" />
                    </VerticalStackLayout>
                </Border>

                <!-- DESCRIÇÃO -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="DESCRIÇÃO" Style="{StaticResource SectionLabelStyle}" />
                        <Entry Text="{Binding Descricao}"
                               Placeholder="Ex: Almoço no restaurante…"
                               FontSize="16" MaxLength="200"
                               TextColor="{StaticResource TextPrimary}"
                               PlaceholderColor="{StaticResource TextMuted}"
                               BackgroundColor="Transparent" />
                        <BoxView HeightRequest="1.5" BackgroundColor="{StaticResource BackgroundColor}" />
                    </VerticalStackLayout>
                </Border>

                <!-- CATEGORIA -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="CATEGORIA" Style="{StaticResource SectionLabelStyle}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="{Binding CategoriaSelecionada}"
                                   FontSize="22" VerticalOptions="Center" />
                        </Grid>
                        <FlexLayout BindableLayout.ItemsSource="{Binding Categorias}"
                                    Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border StrokeShape="RoundRectangle 14" Stroke="Transparent"
                                            BackgroundColor="#F7F5F2" Padding="4" Margin="4"
                                            WidthRequest="52" HeightRequest="52">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer CommandParameter="{Binding .}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                Path=BindingContext.SelecionarCategoriaCommand}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding .}" FontSize="24"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- BOTÃO SALVAR -->
                <Grid RowDefinitions="58, Auto" RowSpacing="12">
                    <Button Grid.Row="0" Text="💾  Salvar Gasto"
                            Command="{Binding SalvarCommand}"
                            BackgroundColor="{StaticResource AccentColor}"
                            TextColor="White" FontSize="16" FontAttributes="Bold"
                            CornerRadius="18" HeightRequest="58"
                            IsVisible="{Binding IsSaving, Converter={toolkit:InvertedBoolConverter}}" />
                    <ActivityIndicator Grid.Row="0"
                            IsRunning="{Binding IsSaving}" IsVisible="{Binding IsSaving}"
                            Color="{StaticResource AccentColor}"
                            HorizontalOptions="Center" VerticalOptions="Center" />
                    <Label Grid.Row="1" Text="Atualizando…" FontSize="12"
                           TextColor="{StaticResource TextMuted}"
                           HorizontalOptions="Center" IsVisible="{Binding IsLoading}" />
                </Grid>

                <!-- LISTA DE GASTOS -->
                <Label Text="LANÇAMENTOS RECENTES" Style="{StaticResource SectionLabelStyle}"
                       Margin="4,8,0,0" />

                <CollectionView ItemsSource="{Binding GastosPorMes}"
                                IsGrouped="True" SelectionMode="None"
                                EmptyView="Nenhum gasto registrado ainda 🎉">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="vm:GastosPorMes">
                            <Grid ColumnDefinitions="*, Auto" Padding="4,16,4,6">
                                <Label Text="{Binding Mes}" FontAttributes="Bold"
                                       FontSize="13" TextColor="{StaticResource TextPrimary}"
                                       TextTransform="Capitalize" VerticalOptions="Center" />
                                <Border Grid.Column="1" StrokeShape="RoundRectangle 10"
                                        Stroke="Transparent"
                                        BackgroundColor="{StaticResource PrimaryColor}"
                                        Padding="10,4">
                                    <Label Text="{Binding TotalFormatado}"
                                           FontAttributes="Bold" FontSize="12" TextColor="White" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:Gasto">
                            <Border Style="{StaticResource CardStyle}" Padding="16,14" Margin="0,4">
                                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="14">
                                    <Border Grid.Column="0" StrokeShape="RoundRectangle 12"
                                            Stroke="Transparent" BackgroundColor="#F7F5F2"
                                            Padding="10" WidthRequest="46" HeightRequest="46"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding Categoria}" FontSize="20"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Descricao}" FontSize="14"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding DataFormatada}" FontSize="11"
                                               TextColor="{StaticResource TextMuted}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding ValorFormatado}"
                                           FontAttributes="Bold" FontSize="15"
                                           TextColor="{StaticResource AccentColor}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="16" BackgroundColor="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- BANNER AD -->
        <Border Grid.Row="1" IsVisible="{Binding ShowBanner}"
                BackgroundColor="#EDE8E1" HeightRequest="60" Padding="0">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12" Padding="16,0">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 6"
                        Stroke="{StaticResource TextMuted}" Padding="4,2" VerticalOptions="Center">
                    <Label Text="AD" FontAttributes="Bold" FontSize="9"
                           TextColor="{StaticResource TextMuted}" />
                </Border>
                <Label Grid.Column="1" Text="Anúncio · Google AdMob" FontSize="12"
                       TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                <Label Grid.Column="2" Text="⭐ Premium" FontAttributes="Bold"
                       FontSize="12" TextColor="{StaticResource AccentColor}" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding IrParaPremiumCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
